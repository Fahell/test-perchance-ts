{
  "name": "test-perchance-ts",
  "version": "1.0.2",
  "type": "module",
  "description": "TypeScript test project for Perchance.org - AI text plugin and Three.js integration",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "perchance",
    "threejs",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Fahell/test-perchance-ts/issues"
  },
  "homepage": "https://github.com/Fahell/test-perchance-ts#readme",
  "devDependencies": {
    "@types/three": "^0.160.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "terser": "^5.39.0",
    "three": "^0.160.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
