{
  "name": "test-perchance-ts",
  "type": "nodejs",
  "version": {
    "files": ["src/constants.ts"],
    "patterns": {
      "src/constants.ts": "export const VERSION = 'v{version}';"
    }
  },
  "hooks": {
    "afterVersionBump": [
      {
        "name": "sync-version",
        "command": "node scripts/sync-version.cjs",
        "description": "Synchronizes version across all project files (CDN URLs, README, etc.)"
      }
    ]
  },
  "build": {
    "command": "npm run build",
    "artifacts": ["dist/main.bundle.js"],
    "minSizeKB": 1,
    "maxSizeKB": 500
  },
  "lint": {
    "enabled": true,
    "command": "npm run lint"
  },
  "tests": {
    "enabled": true,
    "command": "npm test"
  },
  "security": {
    "audit": false,
    "detectSecrets": true
  },
  "pr": {
    "enabled": true,
    "baseBranch": "main",
    "requireCI": true,
    "autoMerge": true,
    "mergeStrategy": "squash"
  },
  "githubRelease": {
    "enabled": true,
    "generateChangelog": true
  }
}
